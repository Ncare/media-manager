# ====== MediaManager configuration ======
# Copy to .env and adjust before `docker compose up -d`

# TMDB API key (free): https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# TMDB metadata language (zh-CN / en-US / ja-JP ...)
TMDB_LANGUAGE=zh-CN

# Your NAS media directory, mapped to /media inside the container (read-write)
MEDIA_DIR=./media

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=80

# Build target: prod (nginx) or dev (vite HMR)
BUILD_TARGET=prod

# CORS origins for backend (dev: http://localhost:5173 ; prod: *)
CORS_ORIGINS=*

# UID/GID for file ownership on mounted volumes (match your NAS user)
PUID=1000
PGID=1000
